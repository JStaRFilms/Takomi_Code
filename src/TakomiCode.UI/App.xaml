<Application
    x:Class="TakomiCode.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TakomiCode.UI"
    xmlns:converters="using:TakomiCode.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- v6 Color System - Premium Minimalist -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0C0C0D" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#151516" />
            <SolidColorBrush x:Key="ElevatedBrush" Color="#1E1E1F" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FACC15" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="#26FACC15" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8" />
            <SolidColorBrush x:Key="BorderBrush" Color="#1Affffff" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
            <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
            <SolidColorBrush x:Key="SidebarBrush" Color="#0C0C0D" />
            <SolidColorBrush x:Key="GlassBrush" Color="#CC151516" />
            <SolidColorBrush x:Key="FolderBrush" Color="#FACC15" />
            <SolidColorBrush x:Key="FileBrush" Color="#94A3B8" />

            <!-- Typography -->
            <FontFamily x:Key="V6FontFamily">Inter, Segoe UI Variable Text, Segoe UI</FontFamily>
            <FontFamily x:Key="V6MonoFontFamily">JetBrains Mono, Cascadia Code, Consolas</FontFamily>

            <!-- Layout Tokens -->
            <CornerRadius x:Key="V6CardCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="V6ButtonCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="V6IconCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="V6ComposerCornerRadius">10</CornerRadius>
            <CornerRadius x:Key="V6ItemCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="V6PillCornerRadius">4</CornerRadius>
            <CornerRadius x:Key="V6AvatarCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="V6ControlBarCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="V6MessageCornerRadius">8</CornerRadius>
            <Thickness x:Key="V6PagePadding">16</Thickness>
            <Thickness x:Key="V6CardPadding">14</Thickness>
            <Thickness x:Key="V6SidebarPadding">12,10</Thickness>
            <Thickness x:Key="V6CompactPadding">10,8</Thickness>
            <Thickness x:Key="V6ButtonPadding">14,8</Thickness>

            <!-- Reusable Styles -->
            <Style x:Key="V6HeaderLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                <Setter Property="CharacterSpacing" Value="200" />
                <Setter Property="FontFamily" Value="{StaticResource V6FontFamily}" />
            </Style>

            <Style x:Key="V6CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource V6CardCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource V6CardPadding}" />
            </Style>

            <Style x:Key="V6StatusPillStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="9999" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="V6ComposerTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="PlaceholderForeground" Value="{StaticResource TextMutedBrush}" />
            </Style>

            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
