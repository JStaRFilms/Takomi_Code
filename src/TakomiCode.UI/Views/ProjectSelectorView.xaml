<UserControl
    x:Class="TakomiCode.UI.Views.ProjectSelectorView"
    x:Name="ProjectSelectorRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TakomiCode.UI.ViewModels">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Ellipse
            Width="600"
            Height="600"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.3">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#18FACC15" Offset="0" />
                    <GradientStop Color="#00FACC15" Offset="0.8" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="900"
                Margin="0,80,0,80"
                HorizontalAlignment="Center"
                Spacing="56">

                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Border
                        Width="64"
                        Height="64"
                        HorizontalAlignment="Center"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="{StaticResource V6AvatarCornerRadius}">
                        <Viewbox Margin="16">
                            <FontIcon Glyph="&#xE8B7;" Foreground="{StaticResource AppBackgroundBrush}" />
                        </Viewbox>
                    </Border>
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Select a workspace"
                            FontSize="36"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            Foreground="White" />
                        <TextBlock
                            Text="Open an existing project and resume Takomi orchestration."
                            FontSize="15"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <Grid MaxWidth="440" HorizontalAlignment="Center">
                    <Border
                        Padding="{StaticResource V6CompactPadding}"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource V6CardCornerRadius}"
                        Opacity="0.8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE721;" Foreground="{StaticResource TextMutedBrush}" FontSize="16" />
                            <TextBlock
                                Grid.Column="1"
                                Text="Search projects..."
                                FontSize="14"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextMutedBrush}" />
                        </Grid>
                    </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding RecentWorkspaces}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="440" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:WorkspaceViewModel">
                            <Button
                                Margin="8"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding ElementName=ProjectSelectorRoot, Path=DataContext.InitializeProjectCommand}"
                                CommandParameter="{Binding}">
                                <Border
                                    Padding="24"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource V6CardCornerRadius}">
                                    <Grid RowSpacing="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Border
                                                Width="44"
                                                Height="44"
                                                HorizontalAlignment="Left"
                                                Background="{StaticResource AccentMutedBrush}"
                                                CornerRadius="{StaticResource V6IconCornerRadius}">
                                                <Viewbox Margin="10">
                                                    <FontIcon Glyph="&#xE8B7;" Foreground="{StaticResource AccentBrush}" />
                                                </Viewbox>
                                            </Border>
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Text="{Binding LastOpenedFormatted}"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontFamily="{StaticResource V6MonoFontFamily}"
                                                CharacterSpacing="100" />
                                        </Grid>

                                        <StackPanel Grid.Row="1" Spacing="4">
                                            <TextBlock
                                                Text="{Binding Name}"
                                                FontSize="19"
                                                FontWeight="SemiBold"
                                                Foreground="White" />
                                            <TextBlock
                                                Text="{Binding Path}"
                                                FontSize="13"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontFamily="{StaticResource V6MonoFontFamily}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                                <TextBlock
                                                    Text="Recent workspace"
                                                    FontSize="11"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    FontFamily="{StaticResource V6MonoFontFamily}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE9A1;" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding Id}"
                                                    FontSize="11"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    FontFamily="{StaticResource V6MonoFontFamily}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Spacing="24">
                    <Button
                        HorizontalAlignment="Center"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        IsEnabled="False"
                        Opacity="0.55">
                        <Border
                            Width="440"
                            Padding="24"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource V6CardCornerRadius}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                                <FontIcon Glyph="&#xE710;" Foreground="{StaticResource TextMutedBrush}" FontSize="16" />
                                <TextBlock
                                    Text="Initialize new project"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>
                    </Button>

                    <TextBlock
                        HorizontalAlignment="Center"
                        Text="Takomi v6.0.0-alpha"
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontFamily="{StaticResource V6MonoFontFamily}"
                        CharacterSpacing="200" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
