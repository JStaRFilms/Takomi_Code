<UserControl
    x:Class="TakomiCode.UI.Views.SessionsWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TakomiCode.UI.Controls">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar: Sessions List -->
        <Border
            Grid.Column="0"
            Width="272"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0"
            Visibility="{Binding IsLeftSidebarOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Padding="{StaticResource V6PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Text="Sessions"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White" />
                    <TextBlock
                        Text="{Binding WorkspaceName}"
                        FontSize="11"
                        Foreground="{StaticResource TextMutedBrush}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Margin="0,16,0,12"
                    Padding="{StaticResource V6CompactPadding}"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource V6CardCornerRadius}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE721;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock
                            Text="Search sessions..."
                            FontSize="12"
                            Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </Border>

                <ListView
                    Grid.Row="2"
                    ItemsSource="{Binding Sessions}"
                    SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                    SelectionMode="Single"
                    Background="Transparent"
                    BorderThickness="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,4" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="{StaticResource V6SidebarPadding}"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource V6ItemCornerRadius}">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border
                                            Width="20"
                                            Height="20"
                                            Background="{StaticResource AccentMutedBrush}"
                                            CornerRadius="4">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="10" Foreground="{StaticResource FolderBrush}" />
                                        </Border>
                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontSize="12"
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding WorktreePath}"
                                        Margin="28,0,0,0"
                                        FontSize="10"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        FontFamily="{StaticResource V6MonoFontFamily}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button
                    Grid.Row="3"
                    Click="CreateChatButton_Click"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource AppBackgroundBrush}"
                    FontWeight="SemiBold"
                    Padding="{StaticResource V6ButtonPadding}"
                    CornerRadius="{StaticResource V6ButtonCornerRadius}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                        <TextBlock Text="New Session" FontSize="12" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Chat Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border
                Grid.Row="0"
                Background="{StaticResource AppBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid Padding="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{Binding ToggleLeftSidebarCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            ToolTipService.ToolTip="Toggle Sessions (Ctrl+B)">
                            <FontIcon Glyph="&#xE8A9;" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                        </Button>

                        <Border
                            Padding="10,5"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource V6PillCornerRadius}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock
                                    Text="Context"
                                    Style="{StaticResource V6HeaderLabelStyle}" />
                                <TextBlock
                                    Text="{Binding WorkspaceName}"
                                    FontSize="11"
                                    Foreground="White"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="/"
                                    FontSize="11"
                                    Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock
                                    Text="{Binding CurrentGitBranch}"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontFamily="{StaticResource V6MonoFontFamily}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="8,5"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource V6PillCornerRadius}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="5" Height="5" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock
                                    Text="{Binding RuntimeEngineLabel}"
                                    FontSize="10"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    FontFamily="{StaticResource V6MonoFontFamily}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Text="{Binding StatusMessage}"
                        FontSize="11"
                        Foreground="{StaticResource TextMutedBrush}"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        Grid.Column="2"
                        Command="{Binding ToggleRightSidebarCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        ToolTipService.ToolTip="Toggle Details (Ctrl+I)">
                        <FontIcon Glyph="&#xE99A;" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Messages Stream -->
            <ScrollViewer
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto"
                Padding="0,24,0,24">
                <ItemsControl
                    ItemsSource="{Binding SelectedSession.Messages}"
                    MaxWidth="860"
                    HorizontalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="16,0,16,24">
                                <!-- User Message -->
                                <Border
                                    Visibility="{Binding IsUser, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    HorizontalAlignment="Right"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource V6MessageCornerRadius}"
                                    Padding="16,12"
                                    MaxWidth="660">
                                    <TextBlock
                                        Text="{Binding Content}"
                                        Foreground="White"
                                        FontSize="14"
                                        TextWrapping="Wrap" />
                                </Border>

                                <!-- Assistant Message -->
                                <Grid
                                    Visibility="{Binding IsUser, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                    HorizontalAlignment="Left"
                                    MaxWidth="820"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Width="30"
                                        Height="30"
                                        Background="{StaticResource AccentMutedBrush}"
                                        CornerRadius="{StaticResource V6AvatarCornerRadius}"
                                        VerticalAlignment="Top">
                                        <TextBlock
                                            Text="T"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource AccentBrush}"
                                            FontSize="13"
                                            FontWeight="SemiBold" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                            <TextBlock
                                                Text="Takomi"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                CharacterSpacing="150" />
                                        </StackPanel>

                                        <Border
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource V6MessageCornerRadius}"
                                            Padding="16,14">
                                            <controls:MarkdownMessageView
                                                Text="{Binding Content}"
                                                HorizontalAlignment="Stretch" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Refined Composer Area -->
            <Grid Grid.Row="2" Margin="24,0,24,24">
                <Grid MaxWidth="840" HorizontalAlignment="Stretch">
                    <Border
                        Background="{StaticResource GlassBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource V6ComposerCornerRadius}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 1: Input -->
                            <TextBox
                                Grid.Row="0"
                                Text="{Binding DraftMessage, Mode=TwoWay}"
                                Style="{StaticResource V6ComposerTextBoxStyle}"
                                PlaceholderText="Ask Takomi to resolve something..."
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="48"
                                MaxHeight="300" />

                            <!-- Row 2: Control Bar -->
                            <Border
                                Grid.Row="1"
                                Padding="12,8"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                CornerRadius="0,0,10,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Background="Transparent" BorderThickness="0" Padding="6" ToolTipService.ToolTip="Attach Folder">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="{StaticResource FolderBrush}" />
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="6" ToolTipService.ToolTip="Attach File">
                                            <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{StaticResource FileBrush}" />
                                        </Button>

                                        <Border Width="1" Height="16" Background="{StaticResource BorderBrush}" Margin="4,0" />

                                        <Border
                                            Background="{StaticResource ElevatedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource V6PillCornerRadius}"
                                            Padding="8,4">
                                            <TextBlock
                                                Text="{Binding RuntimeTarget}"
                                                FontSize="10"
                                                Foreground="{StaticResource AccentBrush}"
                                                FontFamily="{StaticResource V6MonoFontFamily}" />
                                        </Border>
                                        <Border
                                            Background="{StaticResource ElevatedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource V6PillCornerRadius}"
                                            Padding="8,4"
                                            MaxWidth="200">
                                            <TextBlock
                                                Text="{Binding CurrentSessionWorktree}"
                                                FontSize="10"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                FontFamily="{StaticResource V6MonoFontFamily}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </StackPanel>

                                    <Button
                                        Click="SendMessageButton_Click"
                                        HorizontalAlignment="Right"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="{StaticResource AppBackgroundBrush}"
                                        FontWeight="SemiBold"
                                        Padding="14,6"
                                        CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                        ToolTipService.ToolTip="Route Message">
                                        <FontIcon Glyph="&#xE724;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Right Sidebar: Session Details -->
        <Border
            Grid.Column="2"
            Width="312"
            Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1,0,0,0"
            Visibility="{Binding IsRightSidebarOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer Padding="{StaticResource V6PagePadding}">
                <StackPanel Spacing="16">
                    <TextBlock
                        Text="Session Details"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="White" />

                    <Border Style="{StaticResource V6CardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="CURRENT RUN"
                                Style="{StaticResource V6HeaderLabelStyle}" />
                            <TextBlock
                                Text="{Binding SelectedRunDisplayName}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="White" />
                            <Border
                                Background="{StaticResource AccentMutedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource V6PillCornerRadius}"
                                Padding="8,4"
                                HorizontalAlignment="Left">
                                <TextBlock
                                    Text="{Binding SelectedRunStatusText}"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AccentBrush}" />
                            </Border>
                            <TextBlock
                                Text="{Binding SelectedRunDetailText}"
                                FontSize="11"
                                Foreground="{StaticResource TextMutedBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource V6CardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="WORKSPACE"
                                Style="{StaticResource V6HeaderLabelStyle}" />
                            <TextBlock
                                Text="{Binding SelectedRunWorkingDirectoryLabel}"
                                FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}"
                                TextWrapping="Wrap"
                                FontFamily="{StaticResource V6MonoFontFamily}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource V6CardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="ACTIVE RUNS"
                                Style="{StaticResource V6HeaderLabelStyle}" />
                            <ListView
                                ItemsSource="{Binding ActiveRuns}"
                                SelectedItem="{Binding SelectedActiveRun, Mode=TwoWay}"
                                SelectionMode="Single"
                                Background="Transparent"
                                BorderThickness="0"
                                MaxHeight="300">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Background="{StaticResource ElevatedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource V6ItemCornerRadius}"
                                            Padding="10">
                                            <StackPanel Spacing="2">
                                                <TextBlock
                                                    Text="{Binding RunId}"
                                                    FontSize="10"
                                                    Foreground="White"
                                                    TextTrimming="CharacterEllipsis"
                                                    FontFamily="{StaticResource V6MonoFontFamily}" />
                                                <TextBlock
                                                    Text="{Binding Status}"
                                                    FontSize="10"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
