<Window
    x:Class="TakomiCode.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="#0E0E11"
          Loaded="RootGrid_Loaded">
        <Grid.Resources>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#141414" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#282828" />
            <SolidColorBrush x:Key="SurfaceAccentBrush" Color="#241B15" />
            <SolidColorBrush x:Key="ElevatedBrush" Color="#282828" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FFB900" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#888888" />
            <SolidColorBrush x:Key="BorderBrush" Color="#333333" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#10893E" />
            <SolidColorBrush x:Key="DangerBrush" Color="#D13438" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FCE100" />
            
            <Style x:Key="Win5HeaderLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                <Setter Property="CharacterSpacing" Value="100" />
            </Style>

            <Style x:Key="StudioCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1F1F1F" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>
        </Grid.Resources>

        <NavigationView x:Name="ShellNavigation"
                        Background="{StaticResource AppBackgroundBrush}"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="LeftCompact"
                        SelectionChanged="ShellNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeNavItem" Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SessionsNavItem" Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="WorktreesNavItem" Content="Worktrees" Tag="Worktrees">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="BillingNavItem" Content="Billing" Tag="Billing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEAFD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem" Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- v5 Studio Header -->
                <Border Grid.Row="0"
                        Background="#1A1A1A"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Padding="24,0">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="PROJECT:" 
                                       Style="{StaticResource Win5HeaderLabelStyle}" 
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding WorkspaceName}" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       VerticalAlignment="Center" />
                            <Border Width="1" Height="16" Background="{StaticResource BorderBrush}" Margin="8,0" />
                            <Border Padding="8,4" 
                                    Background="#141414" 
                                    BorderBrush="#33ffffff" 
                                    BorderThickness="1" 
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding WorkspacePath}" 
                                               FontSize="11" 
                                               Foreground="{StaticResource TextMutedBrush}" 
                                               FontFamily="Cascadia Code, Segoe UI Mono" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Background="{StaticResource AccentBrush}"
                                Foreground="Black"
                                FontWeight="SemiBold"
                                Padding="16,8"
                                CornerRadius="4"
                                Click="CreateChatButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="New Orchestration Session" FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid x:Name="HomeSection">
                            <Grid MaxWidth="1024" HorizontalAlignment="Center" Margin="0,48" RowSpacing="40">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Page Header -->
                                <Grid Grid.Row="0">
                                    <TextBlock Text="Orchestrator Overview" 
                                               FontSize="28" 
                                               FontWeight="SemiBold" 
                                               Foreground="White" 
                                               VerticalAlignment="Bottom" />
                                    <TextBlock Text="Status: Connected to Runtime" 
                                               FontSize="12" 
                                               Foreground="{StaticResource TextMutedBrush}" 
                                               FontFamily="Cascadia Code"
                                               HorizontalAlignment="Right" 
                                               VerticalAlignment="Bottom" />
                                </Grid>

                                <!-- Status Grid -->
                                <Grid Grid.Row="1" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Runtime Card -->
                                    <Border Grid.Column="0" Style="{StaticResource StudioCardStyle}" Padding="20">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="RUNTIME ENGINE" Style="{StaticResource Win5HeaderLabelStyle}" Margin="0,0,0,8" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Grid Width="20" Height="20">
                                                    <Ellipse Fill="{StaticResource SuccessBrush}" Opacity="0.2" />
                                                    <Ellipse Fill="{StaticResource SuccessBrush}" Width="8" Height="8" />
                                                </Grid>
                                                <TextBlock Text="{Binding RuntimeTarget}" 
                                                           Foreground="White" 
                                                           FontWeight="SemiBold" 
                                                           FontSize="14" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding RuntimeEngineLabel}" 
                                                       FontSize="10" 
                                                       Foreground="{StaticResource TextMutedBrush}" 
                                                       FontFamily="Cascadia Code" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Branch Card -->
                                    <Border Grid.Column="1" Style="{StaticResource StudioCardStyle}" Padding="20">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="PARENT GIT BRANCH" Style="{StaticResource Win5HeaderLabelStyle}" Margin="0,0,0,8" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8B7;" FontSize="16" Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding CurrentGitBranch}" 
                                                           Foreground="White" 
                                                           FontWeight="SemiBold" 
                                                           FontSize="14" />
                                            </StackPanel>
                                            <TextBlock Text="1 active worktree" 
                                                       FontSize="10" 
                                                       Foreground="{StaticResource TextMutedBrush}" 
                                                       Padding="24,0,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Attention Alert -->
                                    <Border Grid.Column="2" 
                                            Background="#1F1F1F" 
                                            BorderBrush="{StaticResource DangerBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="12" 
                                            Padding="20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="ATTENTION REQUIRED" Foreground="{StaticResource DangerBrush}" FontSize="10" FontWeight="SemiBold" CharacterSpacing="100" Margin="0,0,0,4" />
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <FontIcon Glyph="&#xEA39;" Foreground="{StaticResource DangerBrush}" FontSize="20" />
                                                    <TextBlock Text="{Binding BlockedRunCountLabel}" 
                                                               Foreground="White" 
                                                               FontSize="16" 
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    HorizontalAlignment="Right" 
                                                    VerticalAlignment="Center"
                                                    Content="Resolve Now"
                                                    Background="Transparent"
                                                    BorderBrush="{StaticResource DangerBrush}"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    BorderThickness="1"
                                                    Padding="16,6"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Tag="Sessions"
                                                    Click="ShellShortcutButton_Click"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Sessions Table -->
                                <Border Grid.Row="2" Style="{StaticResource StudioCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                            <TextBlock Text="Recent Sessions" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                        </Border>

                                        <Grid Grid.Row="1" Background="#121212" Padding="24,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2.5*" />
                                                <ColumnDefinition Width="3*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="SESSION ID" Style="{StaticResource Win5HeaderLabelStyle}" />
                                            <TextBlock Grid.Column="1" Text="STATUS" Style="{StaticResource Win5HeaderLabelStyle}" />
                                            <TextBlock Grid.Column="2" Text="WORKTREE" Style="{StaticResource Win5HeaderLabelStyle}" />
                                            <TextBlock Grid.Column="3" Text="LAST ACTIVE" Style="{StaticResource Win5HeaderLabelStyle}" HorizontalAlignment="Right" />
                                        </Grid>

                                        <ListView Grid.Row="2" 
                                                  ItemsSource="{Binding Sessions}"
                                                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                                  Background="#121212"
                                                  BorderThickness="0"
                                                  Padding="0"
                                                  SelectionMode="Single">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="MinHeight" Value="48" />
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="24,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="5*" />
                                                            <ColumnDefinition Width="1.5*" />
                                                            <ColumnDefinition Width="2.5*" />
                                                            <ColumnDefinition Width="3*" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>

                                                        <Border Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="8,2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="#1A1A1A">
                                                            <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                                        </Border>

                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                            <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                                            <TextBlock Text="{Binding WorktreePath}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Code" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="3" Text="{Binding LastActiveFormatted}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Code" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="SessionsSection" Visibility="Collapsed">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="18"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Project Threads"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />

                                        <Grid Grid.Row="1" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="New Chat" Click="CreateChatButton_Click" />
                                            <Button Grid.Column="1" Content="New Child" Click="CreateChildSessionButton_Click" />
                                        </Grid>

                                        <ListView Grid.Row="2"
                                                  ItemsSource="{Binding Sessions}"
                                                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                                  DisplayMemberPath="Title"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Foreground="White" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" RowSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Padding="20"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding CurrentSessionTitle}"
                                                       Foreground="White"
                                                       FontSize="24"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CurrentSessionWorktree}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="The session area now acts like a dedicated top-level surface instead of sharing one crowded startup page."
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Padding="20"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid RowSpacing="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Transcript"
                                                       Foreground="White"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />

                                            <ListView Grid.Row="1"
                                                      ItemsSource="{Binding SelectedSession.Messages}"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Foreground="White">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10"
                                                                Padding="12"
                                                                Background="{StaticResource SurfaceAltBrush}"
                                                                CornerRadius="12">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding Role}"
                                                                           Foreground="{StaticResource AccentBrush}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Content}"
                                                                           Foreground="White"
                                                                           TextWrapping="WrapWholeWords" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Padding="16"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding DraftMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="Add a transcript note or orchestration instruction" />
                                            <Button Grid.Column="1"
                                                    Content="Save Message"
                                                    Click="SendMessageButton_Click" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid x:Name="WorktreesSection" Visibility="Collapsed">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Workspace Manager"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding WorkspacePath}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="This area is reserved for worktree routing, branch context, and workspace attachments."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                        <Border Padding="16"
                                                Background="{StaticResource SurfaceAltBrush}"
                                                CornerRadius="14">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Git State"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding CurrentGitBranch}"
                                                           Foreground="White"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding GitDirtyIndicator}"
                                                           Foreground="{StaticResource DangerBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Padding="20"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Routing Notes"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Current session"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding CurrentSessionTitle}"
                                                   Foreground="White" />
                                        <TextBlock Text="Current worktree"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding CurrentSessionWorktree}"
                                                   Foreground="White"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="BillingSection" Visibility="Collapsed">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Billing"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding BillingStatusText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBox Text="{Binding BillingEmail, Mode=TwoWay}"
                                                 PlaceholderText="Billing email" />
                                        <TextBlock Text="This page is isolated so billing status no longer competes with session controls on first launch."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Bags Verification"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VerificationStatusText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBox Text="{Binding BagsTokenAddress, Mode=TwoWay}"
                                                 PlaceholderText="Bags token address" />
                                        <TextBlock Text="Verification readiness is now grouped with its own context rather than mixed into the landing screen."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="SettingsSection" Visibility="Collapsed">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Runtime Settings"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Select where orchestration runs should execute."
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <ComboBox SelectedItem="{Binding RuntimeTarget, Mode=TwoWay}">
                                            <x:String>Local</x:String>
                                            <x:String>Cloud</x:String>
                                        </ComboBox>
                                        <Border Padding="16"
                                                Background="{StaticResource SurfaceAltBrush}"
                                                CornerRadius="14">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Runtime Surface"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding RuntimeEngineLabel}"
                                                           Foreground="White"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Padding="20"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Notes"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="This page follows the runtime-settings direction you preferred: dedicated, calmer, and more desktop-like."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
