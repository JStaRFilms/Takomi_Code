<Window
    x:Class="TakomiCode.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TakomiCode.UI"
    xmlns:viewModels="using:TakomiCode.UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="3" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16">
            <StackPanel>
                <TextBlock Text="Takomi Code Session Core" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" Margin="0,4,0,0" Opacity="0.8" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,16,8,16"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="8">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="New Chat" Click="CreateChatButton_Click" />
                    <Button Content="New Child" Click="CreateChildSessionButton_Click" />
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ChatSessionViewModel">
                            <StackPanel Spacing="2" Padding="0,4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind WorkspaceId}" FontSize="12" Opacity="0.7" />
                                <TextBlock Text="{x:Bind ParentSessionId}" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="8,16,16,16"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="8">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentSessionTitle}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding CurrentSessionWorktree}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Text="|" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentGitBranch}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding GitDirtyIndicator}" FontSize="12" Foreground="Goldenrod" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button Content="New Worktree" Command="{Binding CreateWorktreeCommand}" Padding="8,2" FontSize="10" />
                        
                        <TextBox PlaceholderText="Enter new worktree path..." Text="{Binding TargetWorktreePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="180" Height="28" Padding="4,2" FontSize="12" />
                        <Button Content="Switch" Command="{Binding SwitchWorktreeCommand}" Padding="8,2" FontSize="10" />
                    </StackPanel>
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding SelectedSession.Messages}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ChatMessageViewModel">
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Role}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Content}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{x:Bind Timestamp}" FontSize="12" Opacity="0.6" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBox Text="{Binding DraftMessage, Mode=TwoWay}" PlaceholderText="Type a message to persist into the transcript" />
                    <Button Content="Save Message" HorizontalAlignment="Right" Click="SendMessageButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Active Runs Pane -->
        <Border Grid.Row="1"
                Grid.Column="2"
                Margin="8,16,16,16"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="8">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Active Runs" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Select a run to intervene" FontSize="12" Opacity="0.7" />
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding ActiveRuns}"
                          SelectedItem="{Binding SelectedActiveRun, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2" Padding="0,4">
                                <TextBlock Text="{Binding TaskId}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RunId}" FontSize="12" Opacity="0.7" />
                                <TextBlock Text="{Binding Status}" FontSize="12" Opacity="0.7" Foreground="{ThemeResource SystemAccentColor}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Spacing="4">
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Pause" Command="{Binding PauseRunCommand}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Resume" Command="{Binding ResumeRunCommand}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelRunCommand}" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Reroute" Command="{Binding RerouteRunCommand}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Guidance" Command="{Binding InjectGuidanceCommand}" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Replace" Command="{Binding ReplaceRunCommand}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Migrate" Command="{Binding MigrateRunCommand}" HorizontalAlignment="Stretch" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Margin="16,0,16,16"
                Padding="12"
                Background="{ThemeResource LayerFillColorAltBrush}"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Project-scoped chats, child session inheritance, transcript restore, and billing state are handled through local repositories and service adapters." VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Status:" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding BillingStatusText}" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColorLight2}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBox Text="{Binding BillingEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="180" PlaceholderText="Paystack customer email" />
                        <Button Content="Start Paystack Checkout" Command="{Binding InitiateCheckoutCommand}" Style="{ThemeResource AccentButtonStyle}" Padding="12,4" />
                        <Button Content="Confirm Paystack Success" Command="{Binding ConfirmCheckoutSuccessCommand}" Padding="12,4" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <TextBlock Text="Pending Ref:" Opacity="0.7" />
                        <TextBlock Text="{Binding PendingBillingReference}" FontFamily="Consolas" />
                        <TextBlock Text="Checkout URL:" Opacity="0.7" />
                        <TextBlock Text="{Binding BillingCheckoutUrl}" MaxWidth="320" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
