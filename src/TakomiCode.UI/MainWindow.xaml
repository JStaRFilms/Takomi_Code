<Window
    x:Class="TakomiCode.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:TakomiCode.UI.Views"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{StaticResource AppBackgroundBrush}" Loaded="RootGrid_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0"
            Visibility="{Binding IsProjectOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Padding="0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Center"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="{StaticResource V6IconCornerRadius}">
                    <Viewbox Margin="8">
                        <FontIcon Glyph="&#xE8B7;" Foreground="{StaticResource AppBackgroundBrush}" />
                    </Viewbox>
                </Border>

                <NavigationView
                    x:Name="ShellNavigation"
                    Grid.Row="1"
                    Margin="0,32,0,0"
                    Background="Transparent"
                    PaneDisplayMode="LeftCompact"
                    CompactPaneLength="72"
                    OpenPaneLength="72"
                    IsBackButtonVisible="Collapsed"
                    IsPaneOpen="False"
                    IsPaneToggleButtonVisible="False"
                    IsSettingsVisible="False"
                    Foreground="{StaticResource TextMutedBrush}"
                    SelectionChanged="ShellNavigation_SelectionChanged">
                    <NavigationView.MenuItems>
                        <NavigationViewItem x:Name="HomeNavItem" Tag="Home" ToolTipService.ToolTip="Overview">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE80F;" Foreground="{StaticResource TextMutedBrush}" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem x:Name="SessionsNavItem" Tag="Sessions" ToolTipService.ToolTip="Sessions">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE8BD;" Foreground="{StaticResource TextMutedBrush}" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem x:Name="WorktreesNavItem" Tag="Worktrees" ToolTipService.ToolTip="Worktrees">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE8B7;" Foreground="{StaticResource TextMutedBrush}" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem x:Name="BillingNavItem" Tag="Billing" ToolTipService.ToolTip="Billing">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xEAFD;" Foreground="{StaticResource TextMutedBrush}" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationView.MenuItems>
                    <NavigationView.FooterMenuItems>
                        <NavigationViewItem x:Name="SettingsNavItem" Tag="Settings" ToolTipService.ToolTip="Settings">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE713;" Foreground="{StaticResource TextMutedBrush}" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationView.FooterMenuItems>
                </NavigationView>

                <Button
                    Grid.Row="2"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource V6IconCornerRadius}"
                    Command="{Binding CloseProjectCommand}"
                    ToolTipService.ToolTip="Close workspace">
                    <FontIcon Glyph="&#xE8BB;" Foreground="{StaticResource TextMutedBrush}" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <views:ProjectSelectorView
                Visibility="{Binding IsProjectOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                DataContext="{Binding}" />

            <Grid Visibility="{Binding IsProjectOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <ScrollViewer Visibility="{Binding IsHomeSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel
                            Padding="{StaticResource V6PagePadding}"
                            MaxWidth="1120"
                            HorizontalAlignment="Center"
                            Spacing="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding ActiveSectionTitle}" FontSize="32" FontWeight="Bold" Foreground="White" />
                                    <TextBlock Text="{Binding ActiveSectionSubtitle}" FontSize="15" Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="{StaticResource AppBackgroundBrush}"
                                    FontWeight="SemiBold"
                                    Padding="{StaticResource V6ButtonPadding}"
                                    CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                    Click="CreateChatButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE710;" />
                                        <TextBlock Text="New Session" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource V6CardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="RUNTIME" Style="{StaticResource V6HeaderLabelStyle}" />
                                        <TextBlock Text="{Binding RuntimeEngineLabel}" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding WorkspacePath}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" FontFamily="{StaticResource V6MonoFontFamily}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource V6CardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="BRANCH" Style="{StaticResource V6HeaderLabelStyle}" />
                                        <TextBlock Text="{Binding CurrentGitBranch}" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding GitDirtyIndicator}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V6MonoFontFamily}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource V6CardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="SESSIONS" Style="{StaticResource V6HeaderLabelStyle}" />
                                        <TextBlock Text="{Binding SessionCount}" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="Chats saved in this workspace" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource V6CardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="RUNS" Style="{StaticResource V6HeaderLabelStyle}" />
                                        <TextBlock Text="{Binding ActiveRunCount}" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding BlockedRunCountLabel}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Padding="0" Background="Transparent" BorderThickness="0" Click="ShellShortcutButton_Click" Tag="Sessions">
                                    <Border Style="{StaticResource V6CardStyle}">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="SESSIONS" Style="{StaticResource V6HeaderLabelStyle}" />
                                            <TextBlock Text="Open the active transcript workspace." FontSize="14" Foreground="White" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Button>

                                <Button Grid.Column="1" Padding="0" Background="Transparent" BorderThickness="0" Click="ShellShortcutButton_Click" Tag="Worktrees">
                                    <Border Style="{StaticResource V6CardStyle}">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="WORKTREES" Style="{StaticResource V6HeaderLabelStyle}" />
                                            <TextBlock Text="Create or switch the selected session worktree." FontSize="14" Foreground="White" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Button>

                                <Button Grid.Column="2" Padding="0" Background="Transparent" BorderThickness="0" Click="ShellShortcutButton_Click" Tag="Billing">
                                    <Border Style="{StaticResource V6CardStyle}">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="BILLING" Style="{StaticResource V6HeaderLabelStyle}" />
                                            <TextBlock Text="Check Paystack state and Bags verification readiness." FontSize="14" Foreground="White" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </Grid>

                            <StackPanel Spacing="18">
                                <TextBlock Text="Recent Sessions" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                                <ItemsControl ItemsSource="{Binding Sessions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Style="{StaticResource V6CardStyle}"
                                                Width="540"
                                                Margin="0,0,16,16">
                                                <Grid RowSpacing="10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border
                                                            Width="28"
                                                            Height="28"
                                                            Background="{StaticResource AccentMutedBrush}"
                                                            CornerRadius="{StaticResource V6IconCornerRadius}">
                                                            <FontIcon Glyph="&#xE8B7;" Foreground="{StaticResource FolderBrush}" FontSize="12" />
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="{Binding LastActiveFormatted}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding WorktreePath}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V6MonoFontFamily}" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="Messages:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                            <TextBlock Text="{Binding Messages.Count}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="Updated:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                            <TextBlock Text="{Binding LastActiveFormatted}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <views:SessionsWorkspaceView
                        Visibility="{Binding IsSessionsSection, Converter={StaticResource BooleanToVisibilityConverter}}"
                        DataContext="{Binding}" />

                    <ScrollViewer Visibility="{Binding IsWorktreesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Padding="{StaticResource V6PagePadding}" MaxWidth="900" HorizontalAlignment="Center" Spacing="24">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ActiveSectionTitle}" FontSize="32" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="{Binding ActiveSectionSubtitle}" FontSize="15" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>

                            <Border Style="{StaticResource V6CardStyle}">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Current Session Worktree" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding CurrentSessionWorktree}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V6MonoFontFamily}" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Target Worktree Path" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                                        <TextBox
                                            Text="{Binding TargetWorktreePath, Mode=TwoWay}"
                                            PlaceholderText="Enter target worktree path"
                                            Background="{StaticResource AppBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button
                                            Command="{Binding CreateWorktreeCommand}"
                                            Background="{StaticResource AccentBrush}"
                                            Foreground="{StaticResource AppBackgroundBrush}"
                                            FontWeight="SemiBold"
                                            Padding="{StaticResource V6ButtonPadding}"
                                            CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                            Content="Create Worktree" />
                                        <Button
                                            Command="{Binding SwitchWorktreeCommand}"
                                            Background="{StaticResource SurfaceBrush}"
                                            Foreground="White"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="{StaticResource V6ButtonPadding}"
                                            CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                            Content="Switch Worktree" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer Visibility="{Binding IsBillingSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Padding="{StaticResource V6PagePadding}" MaxWidth="980" HorizontalAlignment="Center" Spacing="24">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ActiveSectionTitle}" FontSize="32" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="{Binding ActiveSectionSubtitle}" FontSize="15" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource V6CardStyle}">
                                    <StackPanel Spacing="18">
                                        <TextBlock Text="Paystack" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding BillingStatusText}" FontSize="14" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                        <TextBox
                                            Text="{Binding BillingEmail, Mode=TwoWay}"
                                            PlaceholderText="Billing email"
                                            Background="{StaticResource AppBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Button
                                                Command="{Binding InitiateCheckoutCommand}"
                                                Background="{StaticResource AccentBrush}"
                                                Foreground="{StaticResource AppBackgroundBrush}"
                                                FontWeight="SemiBold"
                                                Padding="{StaticResource V6ButtonPadding}"
                                                CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                                Content="Start Checkout" />
                                            <Button
                                                Command="{Binding ConfirmCheckoutSuccessCommand}"
                                                Background="{StaticResource SurfaceBrush}"
                                                Foreground="White"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="{StaticResource V6ButtonPadding}"
                                                CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                                Content="Confirm Success" />
                                        </StackPanel>
                                        <TextBlock
                                            Text="{Binding BillingCheckoutUrl}"
                                            FontSize="11"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            FontFamily="{StaticResource V6MonoFontFamily}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding HasPendingCheckout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource V6CardStyle}">
                                    <StackPanel Spacing="18">
                                        <TextBlock Text="Bags Verification" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding VerificationStatusText}" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBox
                                            Text="{Binding BagsTokenAddress, Mode=TwoWay}"
                                            PlaceholderText="Bags token address"
                                            Background="{StaticResource AppBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Button
                                                Command="{Binding LinkBagsTokenCommand}"
                                                Background="{StaticResource AccentBrush}"
                                                Foreground="{StaticResource AppBackgroundBrush}"
                                                FontWeight="SemiBold"
                                                Padding="{StaticResource V6ButtonPadding}"
                                                CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                                Content="Link Token" />
                                            <Button
                                                Command="{Binding CheckVerificationReadinessCommand}"
                                                Background="{StaticResource SurfaceBrush}"
                                                Foreground="White"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="{StaticResource V6ButtonPadding}"
                                                CornerRadius="{StaticResource V6ButtonCornerRadius}"
                                                Content="Check Readiness" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer Visibility="{Binding IsSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Padding="{StaticResource V6PagePadding}" MaxWidth="900" HorizontalAlignment="Center" Spacing="24">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ActiveSectionTitle}" FontSize="32" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="{Binding ActiveSectionSubtitle}" FontSize="15" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>

                            <Border Style="{StaticResource V6CardStyle}">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Runtime Target" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                                        <ComboBox
                                            SelectedValue="{Binding RuntimeTarget, Mode=TwoWay}"
                                            SelectedValuePath="Tag"
                                            Background="{StaticResource AppBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}">
                                            <ComboBoxItem Content="Local" Tag="Local" />
                                            <ComboBoxItem Content="Cloud" Tag="Cloud" />
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Workspace Root" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding WorkspacePath}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V6MonoFontFamily}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Border
                    Grid.Row="1"
                    Height="32"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                    <Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="{Binding StatusMessage}"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="Takomi v6"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontFamily="{StaticResource V6MonoFontFamily}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
