<Window
    x:Class="TakomiCode.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TakomiCode.UI"
    xmlns:viewModels="using:TakomiCode.UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="2" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16">
            <StackPanel>
                <TextBlock Text="Takomi Code Session Core" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" Margin="0,4,0,0" Opacity="0.8" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,16,8,16"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="8">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="New Chat" Click="CreateChatButton_Click" />
                    <Button Content="New Child" Click="CreateChildSessionButton_Click" />
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ChatSessionViewModel">
                            <StackPanel Spacing="2" Padding="0,4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind WorkspaceId}" FontSize="12" Opacity="0.7" />
                                <TextBlock Text="{x:Bind ParentSessionId}" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="8,16,16,16"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="8">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentSessionTitle}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentSessionWorktree}"
                               FontSize="12"
                               Opacity="0.7" />
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding SelectedSession.Messages}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ChatMessageViewModel">
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Role}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Content}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{x:Bind Timestamp}" FontSize="12" Opacity="0.6" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBox Text="{Binding DraftMessage, Mode=TwoWay}" PlaceholderText="Type a message to persist into the transcript" />
                    <Button Content="Save Message" HorizontalAlignment="Right" Click="SendMessageButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="16,0,16,16"
                Padding="12"
                Background="{ThemeResource LayerFillColorAltBrush}"
                CornerRadius="8">
            <TextBlock Text="Project-scoped chats, child session inheritance, and transcript restore are handled through the local session repository." />
        </Border>
    </Grid>
</Window>
