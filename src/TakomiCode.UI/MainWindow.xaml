<Window
    x:Class="TakomiCode.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:TakomiCode.UI.Converters"
    xmlns:views="using:TakomiCode.UI.Views"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="{StaticResource AppBackgroundBrush}"
          Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <Grid.Resources>
            <Style x:Key="SettingsSubNavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            </Style>

            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        </Grid.Resources>

        <Grid Grid.Row="0">
            <!-- Project Selection Surface -->
            <views:ProjectSelectorView 
                Visibility="{Binding IsProjectOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

            <!-- App Studio Shell -->
            <NavigationView x:Name="ShellNavigation"
                            Visibility="{Binding IsProjectOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="Transparent"
                            IsBackButtonVisible="Collapsed"
                            IsSettingsVisible="False"
                            PaneDisplayMode="LeftCompact"
                            CompactPaneLength="64"
                            OpenPaneLength="220"
                            SelectionChanged="ShellNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeNavItem" Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SessionsNavItem" Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="WorktreesNavItem" Content="Worktrees" Tag="Worktrees">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="BillingNavItem" Content="Billing" Tag="Billing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEAFD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem" Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- v5 Studio Header -->
                <Border Grid.Row="0"
                        Background="#1A1A1A"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Padding="24,0">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="PROJECT:" 
                                       Style="{StaticResource Win5HeaderLabelStyle}" 
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding WorkspaceName}" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       VerticalAlignment="Center" />
                            <Border Width="1" Height="16" Background="{StaticResource BorderBrush}" Margin="8,0" />
                            <Border Padding="8,4" 
                                    Background="{StaticResource AppBackgroundBrush}" 
                                    BorderBrush="#1Affffff" 
                                    BorderThickness="1" 
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding WorkspacePath}" 
                                               FontSize="11" 
                                               Foreground="{StaticResource TextMutedBrush}" 
                                               FontFamily="{StaticResource V5MonoFontFamily}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Background="{StaticResource AccentBrush}"
                                Foreground="Black"
                                FontWeight="SemiBold"
                                Padding="20,8"
                                CornerRadius="4"
                                Click="CreateChatButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="New Orchestration Session" FontSize="13" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid x:Name="HomeSection" Visibility="{Binding IsHomeSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="1024" HorizontalAlignment="Center" Margin="0,64" Spacing="48">
                                
                                <Grid>
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Orchestrator Overview" FontSize="32" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="Local runtime connectivity established." FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="4">
                                        <TextBlock Text="Status: Connected to Runtime" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V5MonoFontFamily}" />
                                        <HyperlinkButton Content="Manage Runtime Settings" Padding="0" Click="ShellShortcutButton_Click" Tag="Settings" FontSize="11" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>

                                <!-- Status Grid -->
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Runtime Card -->
                                    <Button Style="{StaticResource DefaultButtonStyle}" Click="ShellShortcutButton_Click" Tag="Settings" HorizontalAlignment="Stretch" Padding="0" BorderThickness="0">
                                        <Border Style="{StaticResource StudioCardStyle}" Padding="20" HorizontalAlignment="Stretch">
                                            <StackPanel Spacing="12">
                                                <TextBlock Text="RUNTIME ENGINE" Style="{StaticResource Win5HeaderLabelStyle}" />
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="Local Docker" Foreground="White" FontWeight="SemiBold" FontSize="15" />
                                                </StackPanel>
                                                <TextBlock Text="Docker Daemon v24.0.5" FontSize="10" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V5MonoFontFamily}" />
                                            </StackPanel>
                                        </Border>
                                    </Button>

                                    <!-- Context Card -->
                                    <Button Grid.Column="1" Click="ShellShortcutButton_Click" Tag="Worktrees" HorizontalAlignment="Stretch" Padding="0" BorderThickness="0">
                                        <Border Style="{StaticResource StudioCardStyle}" Padding="20" HorizontalAlignment="Stretch">
                                            <StackPanel Spacing="12">
                                                <TextBlock Text="PARENT GIT BRANCH" Style="{StaticResource Win5HeaderLabelStyle}" />
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <FontIcon Glyph="&#xE8B7;" Foreground="{StaticResource TextMutedBrush}" FontSize="18" />
                                                    <TextBlock Text="{Binding CurrentGitBranch}" Foreground="White" FontWeight="SemiBold" FontSize="15" />
                                                </StackPanel>
                                                <TextBlock Text="1 active worktree" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Button>

                                    <!-- Alert Card -->
                                    <Border Grid.Column="2" Padding="20" Background="#1A1A1A" 
                                            BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="12">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="&#xE7BA;" Foreground="{StaticResource DangerBrush}" FontSize="24" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="ATTENTION REQUIRED" Style="{StaticResource Win5HeaderLabelStyle}" Foreground="{StaticResource DangerBrush}" />
                                                <TextBlock Text="{Binding BlockedRunCountLabel}" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="Resolve Now" 
                                                    Background="{StaticResource DangerBrush}" Opacity="0.9"
                                                    Foreground="White" FontSize="12" FontWeight="SemiBold" Padding="16,6" CornerRadius="4"
                                                    Click="ShellShortcutButton_Click" Tag="Sessions" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Recent Sessions Table -->
                                <StackPanel Spacing="20">
                                    <Grid>
                                        <Border Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="16,12">
                                            <TextBlock Text="Recent Sessions" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                                        </Border>
                                        <HyperlinkButton Content="View All Sessions" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0" Click="ShellShortcutButton_Click" Tag="Sessions" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                                    </Grid>
                                    <Border Style="{StaticResource StudioCardStyle}" CornerRadius="0,0,8,8" Padding="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Table Header -->
                                            <Grid Background="#121212" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="SESSION ID" Style="{StaticResource Win5HeaderLabelStyle}" />
                                                <TextBlock Grid.Column="1" Text="STATUS" Style="{StaticResource Win5HeaderLabelStyle}" HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="WORKTREE" Style="{StaticResource Win5HeaderLabelStyle}" />
                                                <TextBlock Grid.Column="3" Text="LAST ACTIVE" Style="{StaticResource Win5HeaderLabelStyle}" HorizontalAlignment="Right" />
                                            </Grid>

                                            <!-- Table Body -->
                                            <ListView Grid.Row="1" ItemsSource="{Binding Sessions}" SelectionMode="None" Padding="0">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="MinHeight" Value="48" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="16,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="150" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            
                                                            <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,2" Background="#1A1A1A" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="4">
                                                                <TextBlock Text="ACTIVE" FontSize="9" FontWeight="Black" Foreground="{StaticResource AccentBrush}" />
                                                            </Border>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                                                <TextBlock Text="{Binding WorktreePath}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource V5MonoFontFamily}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="3" Text="{Binding LastActiveFormatted}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource V5MonoFontFamily}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <Border Height="64" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="SessionsSection" Visibility="{Binding IsSessionsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="320" />
                            </Grid.ColumnDefinitions>

                            <!-- Sessions Explorer (Left) -->
                            <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="SESSIONS" Style="{StaticResource Win5HeaderLabelStyle}" Margin="16,24,16,16" />
                                    
                                    <ListView Grid.Row="1" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession, Mode=TwoWay}" Padding="8">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="12,8" Margin="0,2">
                                                    <StackPanel Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE751;" FontSize="14" Foreground="{StaticResource AccentBrush}" />
                                                            <TextBlock Text="{Binding Title}" FontSize="13" Foreground="White" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Text="ws-a8b2" FontSize="10" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Code" Margin="22,0,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    
                                    <Button Grid.Row="2" Content="New Session" Click="CreateChatButton_Click" Margin="16" HorizontalAlignment="Stretch" />
                                </Grid>
                            </Border>

                            <!-- Central Workspace (Center) -->
                            <Grid Grid.Column="1" Background="#141414">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Workspace Header -->
                                <Border Grid.Row="0" Background="#1F1F1F" Height="40" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8,2">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="CONTEXT" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding WorkspaceName}" FontSize="11" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Text="/" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="ws-a8b2" FontSize="10" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Code" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border Background="#26FFFFFF" Padding="8,2" CornerRadius="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE8BD;" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                                                    <TextBlock Text="Sub-Chat Active" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontFamily="Cascadia Code" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Chat Transcript -->
                                <ScrollViewer Grid.Row="1" Padding="24" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SelectedSession.Messages}" MaxWidth="800" HorizontalAlignment="Center">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,24">
                                                    <!-- User Message -->
                                                    <Border Visibility="{Binding IsUser, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" CornerRadius="12" Padding="16,12" MaxWidth="600">
                                                        <TextBlock Text="{Binding Content}" Foreground="Black" FontSize="14" FontWeight="Medium" TextWrapping="Wrap" />
                                                    </Border>
                                                    
                                                    <!-- Agent Message -->
                                                    <StackPanel Visibility="{Binding IsUser, Converter={StaticResource InverseBooleanToVisibilityConverter}}" HorizontalAlignment="Left" Orientation="Horizontal" Spacing="16" MaxWidth="700">
                                                        <Border Width="32" Height="32" Background="#1F1F1F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Top">
                                                            <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="{StaticResource DangerBrush}" />
                                                        </Border>
                                                        <StackPanel Spacing="12">
                                                            <Border Background="#1F1414" BorderBrush="#80D13438" BorderThickness="1" CornerRadius="12" Padding="16">
                                                                <StackPanel Spacing="8">
                                                                    <TextBlock Text="Block Encountered: Build Failure" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" />
                                                                    <TextBlock Text="{Binding Content}" FontSize="14" Foreground="White" Opacity="0.9" TextWrapping="Wrap" />
                                                                    <Border Background="Black" Opacity="0.5" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                                                         <TextBlock Text="src/utils.ts(23,15): error TS2304..." FontSize="11" FontFamily="Cascadia Code" Foreground="{StaticResource DangerBrush}" />
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                            <Button Content="Suggest Fix" Padding="16,4" FontSize="12" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Studio Input Area -->
                                <Border Grid.Row="2" Background="#1F1F1F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16">
                                    <StackPanel MaxWidth="800" HorizontalAlignment="Center" Spacing="8">
                                        <Border Background="{StaticResource AppBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                                            <StackPanel>
                                                <Border Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE71B;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                                        </StackPanel>
                                                        <Border HorizontalAlignment="Right" Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,1">
                                                            <TextBlock Text="SUB-CHAT CONTEXT" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Grid>
                                                    <TextBox Text="{Binding DraftMessage, Mode=TwoWay}"
                                                             PlaceholderText="Ask agent to resolve, or provide context..."
                                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                                                             Background="Transparent" BorderThickness="0" Padding="12"
                                                             FontSize="14" />
                                                    <Button Content="Route" Click="SendMessageButton_Click"
                                                            Background="{StaticResource AccentBrush}" Foreground="Black" FontWeight="SemiBold"
                                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12" Padding="16,4" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="Codex runs locally. No fee-sharing. Bags Protocol verified." 
                                                   FontSize="10" FontFamily="Cascadia Code" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Inspector Pane (Right) -->
                            <Border Grid.Column="2" Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Inspector Tabs -->
                                    <Grid Background="#1F1F1F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2" Padding="0,10">
                                            <TextBlock Text="Task Graph" Foreground="White" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" />
                                        </Border>
                                        <Border Grid.Column="1" Padding="0,10">
                                            <TextBlock Text="Artifacts" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <!-- Task Tree Content -->
                                    <ScrollViewer Grid.Row="1" Padding="12">
                                        <StackPanel Spacing="16">
                                            <TextBlock Text="CURRENT EXECUTION" Style="{StaticResource Win5HeaderLabelStyle}" />
                                            
                                            <StackPanel Spacing="8">
                                                <Grid Padding="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <Ellipse Width="12" Height="12" Fill="{StaticResource SuccessBrush}" Opacity="0.3" VerticalAlignment="Center" />
                                                        <TextBlock Text="Understand Requirement" FontSize="12" Foreground="White" />
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <Grid Padding="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <Ellipse Width="12" Height="12" Fill="{StaticResource SuccessBrush}" Opacity="0.3" VerticalAlignment="Center" />
                                                        <TextBlock Text="Generate Code" FontSize="12" Foreground="White" />
                                                    </StackPanel>
                                                </Grid>

                                                <Border Background="#26D13438" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                            <Ellipse Width="12" Height="12" Stroke="{StaticResource DangerBrush}" StrokeThickness="2" VerticalAlignment="Center" />
                                                            <TextBlock Text="Compile TS" FontSize="12" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                        <Button Content="Fix" HorizontalAlignment="Right" Background="{StaticResource DangerBrush}" Foreground="White" FontSize="10" Padding="8,0" Height="20" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Margin="24,0,0,0" Spacing="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="12,0">
                                                    <TextBlock Text="run tsc --noEmit" FontSize="10" Foreground="White" Opacity="0.6" />
                                                </StackPanel>

                                                <Grid Padding="4" Opacity="0.5">
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <Ellipse Width="12" Height="12" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1" StrokeDashArray="2,1" VerticalAlignment="Center" />
                                                        <TextBlock Text="End Run" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                        <Grid x:Name="WorktreesSection" Visibility="{Binding IsWorktreesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Workspace Manager"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding WorkspacePath}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="This area is reserved for worktree routing, branch context, and workspace attachments."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                        <Border Padding="16"
                                                Background="{StaticResource SurfaceAltBrush}"
                                                CornerRadius="14">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Git State"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding CurrentGitBranch}"
                                                           Foreground="White"
                                                           FontSize="18"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding GitDirtyIndicator}"
                                                           Foreground="{StaticResource DangerBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Padding="20"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Routing Notes"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Current session"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding CurrentSessionTitle}"
                                                   Foreground="White" />
                                        <TextBlock Text="Current worktree"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding CurrentSessionWorktree}"
                                                   Foreground="White"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="BillingSection" Visibility="{Binding IsBillingSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Billing"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding BillingStatusText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBox Text="{Binding BillingEmail, Mode=TwoWay}"
                                                 PlaceholderText="Billing email" />
                                        <TextBlock Text="This page is isolated so billing status no longer competes with session controls on first launch."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Padding="24"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Bags Verification"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VerificationStatusText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBox Text="{Binding BagsTokenAddress, Mode=TwoWay}"
                                                 PlaceholderText="Bags token address" />
                                        <TextBlock Text="Verification readiness is now grouped with its own context rather than mixed into the landing screen."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="SettingsSection" Visibility="{Binding IsSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Lateral Settings Nav -->
                                <Border Grid.Column="0" Grid.RowSpan="2" Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,24">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SETTINGS" Style="{StaticResource Win5HeaderLabelStyle}" Margin="12,0,0,16" />
                                        
                                        <Button Content="General" Style="{StaticResource SettingsSubNavButtonStyle}" />
                                        
                                        <Grid>
                                            <Button Content="Runtime Config" 
                                                    Style="{StaticResource SettingsSubNavButtonStyle}" 
                                                    Foreground="White" 
                                                    FontWeight="SemiBold"
                                                    Background="#1Affffff" />
                                            <Border HorizontalAlignment="Left" Width="3" Margin="0,8" Background="{StaticResource AccentBrush}" CornerRadius="0,2,2,0" />
                                        </Grid>

                                        <Button Content="Language Models" Style="{StaticResource SettingsSubNavButtonStyle}" />
                                        <Button Content="Tools &amp; Packages" Style="{StaticResource SettingsSubNavButtonStyle}" />
                                        
                                        <Border Margin="12,12" Background="{StaticResource BorderBrush}" Height="1" HorizontalAlignment="Stretch" />
                                        
                                        <Button Content="Account &amp; Node" Style="{StaticResource SettingsSubNavButtonStyle}" />
                                    </StackPanel>
                                </Border>

                                <!-- Settings Content Panel -->
                                <ScrollViewer Grid.Column="1" Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="800" HorizontalAlignment="Left" Margin="48" Spacing="48">
                                        
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Runtime Configuration" FontSize="32" FontWeight="SemiBold" Foreground="White" />
                                            <TextBlock Text="Manage local execution parameters, sandbox limits, and container behaviors." 
                                                       FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>

                                        <!-- Section: Runtime Target -->
                                        <StackPanel Spacing="24">
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8">
                                                <TextBlock Text="RUNTIME TARGET" Style="{StaticResource Win5HeaderLabelStyle}" Foreground="White" />
                                            </Border>
                                            
                                            <Grid ColumnSpacing="20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Local Card -->
                                                <Border Grid.Column="0" Style="{StaticResource StudioCardStyle}" Padding="20" 
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel Spacing="16">
                                                        <Grid>
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="Local Docker" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                                <TextBlock Text="Default execution target for active sessions." FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Padding="8,2" Background="{StaticResource AccentBrush}" CornerRadius="4">
                                                                <TextBlock Text="ACTIVE" FontSize="9" FontWeight="Black" Foreground="Black" />
                                                            </Border>
                                                        </Grid>
                                                        <Border Background="#141414" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="Codex CLI: PROD-READY" FontSize="10" FontFamily="{StaticResource V5MonoFontFamily}" Foreground="{StaticResource TextMutedBrush}" />
                                                                <TextBlock Text="{Binding WorkspacePath}" FontSize="10" FontFamily="{StaticResource V5MonoFontFamily}" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Cloud Card -->
                                                <Border Grid.Column="1" Style="{StaticResource StudioCardStyle}" Padding="20">
                                                    <StackPanel Spacing="16">
                                                        <Grid>
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="Cloud Runtime" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                                <TextBlock Text="Remote adapter target for parity testing." FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Padding="8,2" Background="#1Affffff" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                                <TextBlock Text="STANDBY" FontSize="9" FontWeight="Black" Foreground="{StaticResource TextMutedBrush}" />
                                                            </Border>
                                                        </Grid>
                                                        <Border Background="#141414" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="Endpoint: https://runtime.takomi.cloud" FontSize="10" FontFamily="{StaticResource V5MonoFontFamily}" Foreground="{StaticResource TextMutedBrush}" />
                                                                <TextBlock Text="Status: Not Configured" FontSize="10" FontFamily="{StaticResource V5MonoFontFamily}" Foreground="{StaticResource TextMutedBrush}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Section: Execution Environment -->
                                        <StackPanel Spacing="24">
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8">
                                                <TextBlock Text="EXECUTION ENVIRONMENT" Style="{StaticResource Win5HeaderLabelStyle}" Foreground="White" />
                                            </Border>
                                            
                                            <Border Style="{StaticResource StudioCardStyle}" Padding="20" Opacity="0.6">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Text="Compute Sandbox" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                    <TextBlock Text="Define the isolation model for orchestrator runs. Only Docker is supported in this build." 
                                                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                    <ComboBox IsEnabled="False" Width="300" HorizontalAlignment="Left" Background="#141414">
                                                        <ComboBoxItem IsSelected="True">Local Docker Container (Default)</ComboBoxItem>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource StudioCardStyle}" Padding="20">
                                                <Grid>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="Auto-Cleanup Worktrees" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                        <TextBlock Text="Automatically delete git worktrees when a session completes successfully to save disk space." 
                                                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" MaxWidth="500" />
                                                    </StackPanel>
                                                    <ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsOn="True" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- Section: Limits -->
                                        <StackPanel Spacing="24">
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8">
                                                <TextBlock Text="RESOURCE CONSTRAINTS" Style="{StaticResource Win5HeaderLabelStyle}" Foreground="White" />
                                            </Border>
                                            
                                            <Grid ColumnSpacing="20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Grid.Column="0" Style="{StaticResource StudioCardStyle}" Padding="20">
                                                    <StackPanel Spacing="12">
                                                        <TextBlock Text="Max Concurrent Sessions" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                        <TextBlock Text="Maximum active orchestrated runs." FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                        <NumberBox Value="3" SpinButtonPlacementMode="Compact" HorizontalAlignment="Left" Width="120" Background="#141414" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Style="{StaticResource StudioCardStyle}" Padding="20">
                                                    <StackPanel Spacing="12">
                                                        <TextBlock Text="Timeout Per Task Node" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                        <TextBlock Text="Time before agent intervention triggers (seconds)." FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                                        <NumberBox Value="300" SpinButtonPlacementMode="Compact" HorizontalAlignment="Left" Width="120" Background="#141414" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Section: Network -->
                                        <StackPanel Spacing="24">
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8">
                                                <TextBlock Text="NETWORK ACCESS" Style="{StaticResource Win5HeaderLabelStyle}" Foreground="White" />
                                            </Border>
                                            
                                            <Border Style="{StaticResource StudioCardStyle}" Padding="20">
                                                <Grid>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="Unrestricted Outbound Internet" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                                        <TextBlock Text="Allow orchestrator tools and sub-agents to make external HTTP requests during builds." 
                                                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" MaxWidth="500" />
                                                    </StackPanel>
                                                    <ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <Border Height="80" />
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Save Bar -->
                                <Border Grid.Row="1" Grid.Column="1" Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="32,16">
                                    <Button Content="Apply Settings" 
                                            Background="{StaticResource AccentBrush}" 
                                            Foreground="Black" 
                                            FontWeight="SemiBold" 
                                            Padding="32,8"
                                            CornerRadius="4"
                                            HorizontalAlignment="Right" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </NavigationView>
        </Grid>

        <!-- Global Status Bar -->
        <Border Grid.Row="1" Height="24" Background="#0067C0">
            <Grid Padding="12,0">
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE943;" FontSize="12" Foreground="White" />
                        <TextBlock Text="Takomi / Local" FontSize="10" Foreground="White" FontWeight="Bold" FontFamily="Cascadia Code" />
                    </StackPanel>
                    <TextBlock Text="Engine Ready" FontSize="10" Foreground="White" Opacity="0.8" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Bags Protocol Verified" FontSize="10" Foreground="White" Opacity="0.8" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
